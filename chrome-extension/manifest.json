{
  "manifest_version": 3,
  "name": "HERO.Bot Extension",
  "description": "Local Chrome extension to send HERO.Bot states from WhatsApp Web to the Simulator.",
  "version": "0.1.0",
  "permissions": ["tabs", "storage", "activeTab"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HERO.Bot Extension"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
